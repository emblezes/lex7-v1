# ── Base de donnees ───────────────────────────────────────────────
# SQLite (dev local) :
# DATABASE_URL=sqlite+aiosqlite:///data/legix.db
# PostgreSQL (production / Docker) :
DATABASE_URL=postgresql+asyncpg://legix:legix_dev_password@localhost:5432/legix
POSTGRES_PASSWORD=legix_dev_password

# ── IA Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ENRICHMENT_MODEL=claude-haiku-4-5-20251001

# ── Embeddings (Voyage AI) ───────────────────────────────────────
# Optionnel : si vide, utilise sentence-transformers local
VOYAGE_API_KEY=

# ── LangSmith (traces agents) ───────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-...
LANGCHAIN_PROJECT=legix

# ── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-string-in-production
JWT_EXPIRY_HOURS=72

# ── Telegram ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Email SMTP ───────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=legix@example.com

# ── JORF / PISTE (DILA) ─────────────────────────────────────────
PISTE_CLIENT_ID=
PISTE_CLIENT_SECRET=

# ── Frontend ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3006
DASHBOARD_URL=http://localhost:3000

# ── API ──────────────────────────────────────────────────────────
API_PORT=8000
API_WORKERS=1
